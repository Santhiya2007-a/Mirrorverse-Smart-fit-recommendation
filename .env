# Mirrorverse - Environment Configuration
# Production-ready eCommerce for Women's Dresses

# Flask Configuration
FLASK_ENV=development
FLASK_APP=backend.app
FLASK_DEBUG=True

# Database
DATABASE_URL=sqlite:///mirrorverse.db

# Security
SECRET_KEY=mirrorverse-elite-secret-production-key-change-in-prod

# API Keys (Backend Only - DO NOT EXPOSE)
GOOGLE_API_KEY=AIzaSyCJESz0_BYUgQKeIzfJg10TafXEIEl058g
MEDIAPIPE_KEY=your-mediapipe-key-here

# Payment Gateway (Store securely in production)
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key_here

# Frontend (Public URLs)
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_FRONTEND_URL=http://localhost:3000

# Feature Flags
ENABLE_SMART_FIT=true
ENABLE_RECOMMENDATIONS=true
MAX_PRODUCT_LOAD=12
INFINITE_SCROLL_ENABLED=true

# Logging
LOG_LEVEL=INFO
